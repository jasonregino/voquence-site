# Voquence-site env vars. Copy to .env.local and fill in values.

# Resend integration — for email signups on /api/subscribe
# Create an account at https://resend.com and create a contact Audience.
# Until these are set, signups will be logged to the console only.
RESEND_API_KEY=re_xxx
RESEND_AUDIENCE_ID=xxx

# Supabase — for Managed Cloud auth + DB
# Get these from your Supabase dashboard:
# https://supabase.com/dashboard/project/<project-id>/settings/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...                  # safe to expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...                       # server-only, bypasses RLS

# Anthropic — for Managed Cloud Claude proxy (server-only)
# Voquence's master Anthropic key. Used only when serving authenticated
# Managed Cloud subscribers. BYOK users still bring their own key.
ANTHROPIC_API_KEY=sk-ant-xxx
